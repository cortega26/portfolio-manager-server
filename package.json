{
  "name": "portfolio-manager-unified",
  "version": "1.0.0",
  "description": "Desktop portfolio tracker with server-side storage, signal alerts, and ROI analytics",
  "main": "server/index.js",
  "scripts": {
    "doctor": "node scripts/doctor.mjs",
    "dev": "vite",
    "docs:check": "node scripts/check-doc-contracts.mjs",
    "build": "vite build",
    "postbuild": "node scripts/write-commit-stamp.mjs dist/commit.txt",
    "analyze": "cross-env ANALYZE=true npm run build",
    "preview": "vite preview",
    "electron": "node scripts/run-electron.mjs electron",
    "electron:dev": "node scripts/electron-dev.mjs",
    "electron:build": "npm run build && npm run electron",
    "electron:smoke": "npm run build && cross-env ELECTRON_SMOKE_TEST=1 xvfb-run -a node scripts/run-electron.mjs electron",
    "import:csv": "node scripts/import-csv-portfolio.mjs",
    "server": "node server/index.js",
    "lint": "eslint . --max-warnings=0",
    "test": "npm run test:node && vitest run",
    "test:node": "node --enable-source-maps tools/run-tests.mjs --no-coverage",
    "test:node:coverage": "node --enable-source-maps tools/run-tests.mjs",
    "test:fast": "vitest run --coverage=false --reporter=dot",
    "test:coverage": "vitest run --coverage --coverage.reporter=text-summary --coverage.reporter=lcov",
    "test:perf": "node tools/perf/run-perf-suite.mjs",
    "test:e2e": "playwright test",
    "leaks:repo": "gitleaks detect --no-banner",
    "audit:quick": "npm audit --audit-level=critical || true",
    "mutate": "stryker run",
    "mutate:changed": "stryker run --incremental",
    "test:mutation": "npm run mutate",
    "backfill": "node server/cli/backfill.js",
    "verify:deps": "npm ci --no-fund --no-audit",
    "verify:docs": "npm run doctor && npm run docs:check",
    "verify:lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings=0",
    "verify:typecheck": "tsc --pretty false --project tsconfig.typecheck.json",
    "verify:build": "npm run build",
    "smoke:test": "vitest run src/__smoke__/",
    "verify:smoke": "npm run verify:deps && npm run verify:lint && npm run verify:typecheck && npm run verify:build && npm run smoke:test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "clsx": "^1.2.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "decimal.js": "^10.6.0",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.21.1",
    "react-window": "^1.8.11",
    "recharts": "^2.7.2",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.0.0",
    "@eslint/js": "^9.11.1",
    "@playwright/test": "^1.49.1",
    "@stryker-mutator/core": "^9.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.4.3",
    "@types/node": "^20.19.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.2",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.15",
    "c8": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "eslint": "^9.11.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.0",
    "fast-check": "^3.23.2",
    "gitleaks": "file:tools/gitleaks",
    "globals": "^15.9.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^24.0.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.11.3",
    "postcss": "^8.4.33",
    "prettier": "^3.2.5",
    "rollup-plugin-visualizer": "^5.12.0",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "path-to-regexp": "^0.1.13"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,mjs}": [
      "prettier --write",
      "eslint --fix --max-warnings=0 --no-warn-ignored"
    ],
    "*.{json,css,md,html}": [
      "prettier --write"
    ]
  },
  "type": "module",
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=9.0.0"
  }
}
