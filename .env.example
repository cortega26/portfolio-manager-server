# ===========================================
# Portfolio Manager Unified — Environment Variables
# ===========================================
# Copy this file to .env and customize values for your environment.
# Values shown below are safe development defaults.
#
# Server-side variables are loaded when starting the backend
# (npm run server, npm run electron, or npm run electron:dev).
# VITE_* variables are renderer-only and require a Vite restart.

# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Data Storage ---
# Path where the SQLite database and portfolio data live.
DATA_DIR=./data

# --- Feature Flags ---
# Toggle cash accrual and blended benchmark endpoints.
FEATURES_CASH_BENCHMARKS=true
# Collapse daily cash accrual postings into a single monthly INTEREST transaction.
FEATURES_MONTHLY_CASH_POSTING=false
# Posting day for monthly cash interest (1-31 or "last" for end-of-month).
CASH_POSTING_DAY=last

# --- Pricing Providers ---
# Historical close providers: stooq, yahoo, or none.
PRICE_PROVIDER_PRIMARY=stooq
PRICE_PROVIDER_FALLBACK=none
# Intraday latest-quote provider: alpaca, twelvedata, or none.
PRICE_PROVIDER_LATEST=alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
TWELVE_DATA_API_KEY=
TWELVE_DATA_PREPOST=true

# --- Benchmarks ---
# Market benchmarks exposed to the UI and preloaded by the nightly close job.
BENCHMARK_TICKERS=SPY,QQQ
# Default visible benchmark selection in the dashboard; must be a subset of BENCHMARK_TICKERS.
BENCHMARK_DEFAULT_SELECTION=SPY,QQQ

# --- Background Jobs ---
# Enable or disable the nightly close scheduler.
JOB_NIGHTLY_ENABLED=true
# UTC hour (0-23) when the nightly close process runs.
JOB_NIGHTLY_HOUR=4

# --- Cache & Performance ---
# Private cache lifetime (seconds) applied to NAV/returns responses.
API_CACHE_TTL_SECONDS=600
# In-memory TTL for historical/EOD price series (seconds).
PRICE_CACHE_TTL_SECONDS=600
# TTL for intraday prices while the US market is open (seconds).
PRICE_CACHE_LIVE_OPEN_TTL_SECONDS=60
# TTL for latest-only prices outside regular market hours (seconds).
PRICE_CACHE_LIVE_CLOSED_TTL_SECONDS=900
# Interval for the price cache sweeping expired entries (seconds).
PRICE_CACHE_CHECK_PERIOD=120
# Upstream price fetch timeout (milliseconds).
PRICE_FETCH_TIMEOUT_MS=5000
# Maximum trading-day age before returning 503 for stale benchmark data.
FRESHNESS_MAX_STALE_TRADING_DAYS=3

# --- Frontend Overrides ---
# VITE_* variables belong to the Vite renderer build, not the backend.
# Change this if running the frontend against a different backend URL.
VITE_API_BASE=http://localhost:3000
# Content Security Policy for the renderer. Development needs 'unsafe-eval' for Vite HMR.
VITE_APP_CSP=default-src 'self'; script-src 'self' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
